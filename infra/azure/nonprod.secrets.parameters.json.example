{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "namePrefix": { "value": "<short-lowercase-prefix>" },
    "acrName": { "value": "<globally-unique-acr-name>" },
    "storageAccountName": { "value": "<globally-unique-storage-name>" },
    "postgresServerName": { "value": "<globally-unique-postgres-server-name>" },
    "postgresAdministratorPassword": { "value": "<strong-temporary-postgres-password>" },
    "redisCacheName": { "value": "<globally-unique-redis-name>" },
    "frontendOrigin": { "value": "https://<frontend-host>" },
    "workerEntraAuthority": { "value": "https://login.microsoftonline.com/<tenant-id>/v2.0" },
    "workerEntraAudience": { "value": "api://<backend-app-id>" },
    "workerBackendTokenScope": { "value": "api://<backend-app-id>/.default" }
  }
}
