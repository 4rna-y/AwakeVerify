# Supply local-only values in .devcontainer/.env; do not commit that file.
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
# Optional host port override when 5432 is already in use; containers always use postgres:5432.
POSTGRES_HOST_PORT=5432

REDIS_PASSWORD=
# Optional host port override when 6379 is already in use; containers always use redis:6379.
REDIS_HOST_PORT=6379
# Optional host port overrides when Azurite's default public ports are in use.
AZURITE_BLOB_HOST_PORT=10000
AZURITE_QUEUE_HOST_PORT=10001
AZURITE_TABLE_HOST_PORT=10002

MSSQL_SA_PASSWORD=

ADMIN_ID=
ADMIN_PASSWORD=

SERVICEBUS_SAS_KEY=

DATABASE_CONNECTION_STRING=

REDIS_CONNECTION_STRING=

BLOB_CONNECTION_STRING=

SERVICEBUS_CONNECTION_STRING=

BLOB_CONTAINER_NAME=frame-images

SERVICEBUS_QUEUE_NAME=
# Optional host port override when 5672 is already in use; containers always use servicebus:5672.
SERVICEBUS_HOST_PORT=5672
# Local-only Backend authentication for the Worker. Replace before starting the local E2E stack.
WORKER_API_KEY=
WORKER_AUTH_MODE=
WORKER_BACKEND_TOKEN_SCOPE=
WORKER_BACKEND_CLIENT_ID=

# Backend production Entra ID validation settings (set as secret/environment configuration, not in git).
WORKER__AUTHMODE=
WORKER__ENTRA__AUTHORITY=
WORKER__ENTRA__AUDIENCE=
WORKER__ENTRA__VALIDISSUER=

REDIS_PUBSUB_CHANNEL=sd2:drowsiness-score

AZURE_SIGNALR_CONNECTION_STRING=

# IaC sets this to the largest concurrently routable Backend replica count.
# Keep 1 for local single-process SignalR development.
BACKEND_EXPECTED_INSTANCE_COUNT=1
READINESS_TIMEOUT_MS=2000

SIGNALR_HUB_PATH=/hubs/drowsiness

NEXT_PUBLIC_BACKEND_URL=http://localhost:5000

NEXT_PUBLIC_SIGNALR_HUB_URL=http://localhost:5000/hubs/drowsiness
